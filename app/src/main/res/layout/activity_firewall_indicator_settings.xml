<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/firewallIndicatorSettingsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarFirewallIndicator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:title="@string/firewall_indicator_settings_title"
        app:navigationIcon="@drawable/ic_arrow_back_24" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/firewall_indicator_settings_description"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/firewall_indicator_x"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvIndicatorXValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="0"
                    android:textColor="?android:attr/textColorSecondary" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/btnIndicatorXMinus"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/round_button_bg"
                        android:contentDescription="@string/decrease"
                        android:padding="10dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_remove_24px"
                        app:tint="?attr/colorOnSurface" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderIndicatorX"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:valueFrom="0"
                        android:valueTo="2000"
                        android:stepSize="1" />

                    <ImageButton
                        android:id="@+id/btnIndicatorXPlus"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/round_button_bg"
                        android:contentDescription="@string/increase"
                        android:padding="10dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_add_24px"
                        app:tint="?attr/colorOnSurface" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/firewall_indicator_y"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvIndicatorYValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="0"
                    android:textColor="?android:attr/textColorSecondary" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/btnIndicatorYMinus"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/round_button_bg"
                        android:contentDescription="@string/decrease"
                        android:padding="10dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_remove_24px"
                        app:tint="?attr/colorOnSurface" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderIndicatorY"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:valueFrom="-600"
                        android:valueTo="3000"
                        android:stepSize="1" />

                    <ImageButton
                        android:id="@+id/btnIndicatorYPlus"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/round_button_bg"
                        android:contentDescription="@string/increase"
                        android:padding="10dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_add_24px"
                        app:tint="?attr/colorOnSurface" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/firewall_indicator_size"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvIndicatorSizeValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="0"
                    android:textColor="?android:attr/textColorSecondary" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/btnIndicatorSizeMinus"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/round_button_bg"
                        android:contentDescription="@string/decrease"
                        android:padding="10dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_remove_24px"
                        app:tint="?attr/colorOnSurface" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderIndicatorSize"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:valueFrom="24"
                        android:valueTo="180"
                        android:stepSize="1" />

                    <ImageButton
                        android:id="@+id/btnIndicatorSizePlus"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/round_button_bg"
                        android:contentDescription="@string/increase"
                        android:padding="10dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_add_24px"
                        app:tint="?attr/colorOnSurface" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

</LinearLayout>
