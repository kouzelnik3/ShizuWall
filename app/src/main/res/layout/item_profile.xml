<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/profileCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="5dp"
    android:checkable="false"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:rippleColor="?attr/colorPrimary"
    app:strokeColor="@android:color/transparent"
    app:strokeWidth="1.5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingTop="14dp"
        android:paddingEnd="6dp"
        android:paddingBottom="14dp">

        <!-- Leading avatar: profile glyph, swaps to a check ring when active -->
        <FrameLayout
            android:id="@+id/profileAvatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/profile_avatar_bg">

            <ImageView
                android:id="@+id/profileGlyph"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_profiles_24px"
                app:tint="?attr/colorPrimary" />

            <ImageView
                android:id="@+id/profileActiveCheck"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/check_24px"
                android:visibility="gone"
                app:tint="?attr/colorOnPrimary" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/profileName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="?attr/colorOnSurface"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="Home" />

            <TextView
                android:id="@+id/profileSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="13sp"
                tools:text="12 apps · Default" />

        </LinearLayout>

        <TextView
            android:id="@+id/profileActiveBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="2dp"
            android:background="@drawable/profile_active_badge_bg"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="@string/profile_active"
            android:textAllCaps="true"
            android:textColor="?attr/colorOnPrimary"
            android:textSize="10sp"
            android:textStyle="bold"
            android:visibility="gone"
            tools:visibility="visible" />

        <ImageButton
            android:id="@+id/profileMenu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/profile_options"
            android:padding="8dp"
            android:src="@drawable/ic_more_vert_24px"
            app:tint="?attr/colorOnSurfaceVariant" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
